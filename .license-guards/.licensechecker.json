{
  "_comment": "license-checker config for Node projects. Run: npx license-checker --json --production --excludePrivatePackages | node scripts/validate-licenses.mjs",
  "allowed": [
    "MIT",
    "MIT*",
    "Apache-2.0",
    "Apache 2.0",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "BSD",
    "ISC",
    "0BSD",
    "CC0-1.0",
    "CC-BY-4.0",
    "Unlicense",
    "Python-2.0",
    "PSF",
    "Zlib",
    "WTFPL",
    "BlueOak-1.0.0"
  ],
  "blocked": [
    "GPL-1.0",
    "GPL-2.0",
    "GPL-3.0",
    "GPL-1.0+",
    "GPL-2.0+",
    "GPL-3.0+",
    "AGPL-1.0",
    "AGPL-3.0",
    "AGPL-3.0-only",
    "AGPL-3.0-or-later",
    "SSPL-1.0",
    "BUSL-1.1",
    "Commons-Clause",
    "EUPL-1.2",
    "MS-RL",
    "OSL-3.0"
  ],
  "review_required": [
    "LGPL-2.1",
    "LGPL-3.0",
    "MPL-2.0",
    "EPL-2.0",
    "CDDL-1.1",
    "Custom",
    "UNLICENSED",
    "UNKNOWN",
    "NOASSERTION",
    "Other"
  ],
  "exceptions": {
    "_comment": "Per-package overrides — package name + reason. Reviewed quarterly."
  }
}
